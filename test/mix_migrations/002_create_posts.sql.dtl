-- DTL миграция: создание таблицы posts с префиксом
CREATE TABLE {{ prefix }}_posts (
    id SERIAL PRIMARY KEY,
    user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    title VARCHAR(500) NOT NULL,
    content TEXT,
    published BOOLEAN NOT NULL DEFAULT false,
    created_at TIMESTAMP NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMP NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_{{ prefix }}_posts_user_id ON {{ prefix }}_posts(user_id);
CREATE INDEX idx_{{ prefix }}_posts_published ON {{ prefix }}_posts(published);
CREATE INDEX idx_{{ prefix }}_posts_created_at ON {{ prefix }}_posts(created_at);
